{
  "name": "janneh-mini-mart",
  "private": true,
  "version": "1.1.2",
  "type": "module",
  "main": "electron/main.js",

  "repository": {
    "type": "git",
    "url": "https://github.com/chernorjanneh4-gif/janneh-mini-mart.git"
  },
  "homepage": "https://github.com/chernorjanneh4-gif/janneh-mini-mart",

  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "electron:start": "wait-on tcp:3000 && electron .",
    "electron:dev": "concurrently -k \"npm run dev\" \"npm run electron:start\"",
    "build": "vite build",
    "electron:build": "node generate-icon.js && vite build && electron-builder",
    "electron:publish": "node generate-icon.js && vite build && electron-builder --publish always",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },

  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@emailjs/browser": "^4.4.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@google/genai": "^1.29.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "express": "^4.21.2",
    "firebase": "^12.11.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.72.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^13.0.0",
    "vite": "^6.2.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },

  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.2.0",
    "wait-on": "^9.0.4"
  },

  "build": {
    "appId": "com.janneh.minimart",
    "productName": "Janneh Mini-Mart",
    "electronUpdaterCompatibility": ">=2.16",

    "icon": "build/icon.png",

    "directories": {
      "output": "release"
    },

    "publish": [
      {
        "provider": "github",
        "owner": "chernorjanneh4-gif",
        "repo": "janneh-mini-mart"
      }
    ],

    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/icon.png",
      "package.json"
    ],

    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },

    "mac": {
      "target": "dmg"
    },

    "linux": {
      "target": "AppImage"
    }
  }
}
